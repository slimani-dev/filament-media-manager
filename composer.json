{
    "name": "slimani/filament-media-manager",
    "description": "A media manager plugin for Filament.",
    "keywords": [
        "laravel",
        "filament",
        "media-manager",
        "media-library"
    ],
    "homepage": "https://github.com/slimani-dev/filament-media-manager",
    "support": {
        "issues": "https://github.com/slimani-dev/filament-media-manager/issues",
        "source": "https://github.com/slimani-dev/filament-media-manager"
    },
    "authors": [
        {
            "name": "Mohamed Slimani",
            "role": "Developer",
            "email": "mohamed@slimani.dev"
        }
    ],
    "require-dev": {
        "laravel/pint": "^1.0",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Slimani\\MediaManager\\": "src/",
            "Slimani\\MediaManager\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Slimani\\MediaManager\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "pint": "vendor/bin/pint",
        "analyze": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "license": "MIT",
    "require": {
        "laravel/framework": "^12.0|^13.0",
        "codewithdennis/filament-select-tree": "^4.0",
        "filament/filament": "^4.0|^5.0",
        "filament/spatie-laravel-media-library-plugin": "^4.0|^5.0",
        "hugomyb/filament-media-action": "^4.0|^5.0",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-package-tools": "^1.93"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Slimani\\MediaManager\\MediaManagerServiceProvider"
            ]
        }
    }
}